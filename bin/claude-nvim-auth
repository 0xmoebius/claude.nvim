#!/usr/bin/env python3
"""
PreToolUse hook for claude.nvim.

Reads the hook payload from stdin, forwards the tool name + input to the
running nvim instance via --remote-expr, and prints the decision on stdout
in the format Claude Code expects.

Environment:
  CLAUDE_NVIM_SOCKET   Path to v:servername of the caller nvim (required).
  CLAUDE_NVIM_TIMEOUT  Optional override for the remote-expr timeout (seconds).

Exit code is always 0; decisions travel via the JSON on stdout.
"""

from __future__ import annotations
import json
import os
import subprocess
import sys
import tempfile
import time


def respond(decision: str, reason: str) -> None:
    sys.stdout.write(json.dumps({
        "continue": True,
        "suppressOutput": True,
        "hookSpecificOutput": {
            "hookEventName": "PreToolUse",
            "permissionDecision": decision,
            "permissionDecisionReason": reason,
        },
    }))
    sys.stdout.write("\n")
    sys.exit(0)


def run_remote_picker(sock: str, expr: str, timeout_s: int) -> str:
    """Kick off an async picker in nvim via --remote-expr + tempfile handoff,
    poll the tempfile for the answer. Returns the answer string, or raises."""
    fd, answer_path = tempfile.mkstemp(prefix="claude-nvim-ans-", suffix=".txt")
    os.close(fd)
    # Sentinel so we don't mistake "created but empty" for "done".
    with open(answer_path, "w") as f:
        f.write("<IN-FLIGHT>\n")
    full_expr = expr.replace("{ANSWER_PATH}", json.dumps(answer_path))
    try:
        subprocess.run(
            ["nvim", "--server", sock, "--remote-expr", full_expr],
            capture_output=True, text=True, timeout=10,
        )
    except Exception as e:
        try:
            os.unlink(answer_path)
        except OSError:
            pass
        raise RuntimeError(f"nvim unreachable: {e}")
    deadline = time.monotonic() + timeout_s
    while time.monotonic() < deadline:
        try:
            with open(answer_path) as f:
                content = f.read()
        except OSError:
            content = ""
        if content and content != "<IN-FLIGHT>\n":
            try:
                os.unlink(answer_path)
            except OSError:
                pass
            return content.rstrip("\n")
        time.sleep(0.2)
    try:
        os.unlink(answer_path)
    except OSError:
        pass
    raise TimeoutError("picker timed out")


def main() -> None:
    try:
        payload = json.load(sys.stdin)
    except Exception as e:
        respond("deny", f"hook payload parse error: {e}")

    tool_name = payload.get("tool_name", "?")
    tool_input = payload.get("tool_input", {})

    sock = os.environ.get("CLAUDE_NVIM_SOCKET", "").strip()
    if not sock:
        respond("deny", "claude.nvim: no CLAUDE_NVIM_SOCKET set")

    timeout_s = int(os.environ.get("CLAUDE_NVIM_TIMEOUT", "3600"))

    tool_input_lit = json.dumps(json.dumps(tool_input))

    # AskUserQuestion: the CLI's ask-the-user-a-question tool. In -p mode
    # the CLI short-circuits with an error; we intercept here, render a
    # picker in nvim, and surface the answer as the tool_result via
    # deny+reason (the CLI flags it is_error:true, but the reason text IS
    # the answer).
    if tool_name == "AskUserQuestion":
        expr = (
            'v:lua.require("claude.questions").start('
            f'{{ANSWER_PATH}}, {tool_input_lit})'
        )
        try:
            answer = run_remote_picker(sock, expr, timeout_s)
        except (RuntimeError, TimeoutError) as e:
            respond("deny", f"claude.nvim: {e}")
            return
        respond("deny", answer or "(no answer)")
        return

    # Any other matched tool (only when ask_permissions=true) goes through
    # the legacy vim.fn.confirm dialog. Synchronous remote-expr is fine
    # here because vim.fn.confirm pumps its own input loop.
    tool_name_lit = json.dumps(tool_name)
    expr = (
        f'v:lua.require("claude.permissions").prompt('
        f'{tool_name_lit}, {tool_input_lit})'
    )
    try:
        result = subprocess.run(
            ["nvim", "--server", sock, "--remote-expr", expr],
            capture_output=True,
            text=True,
            timeout=timeout_s,
        )
    except subprocess.TimeoutExpired:
        respond("deny", "claude.nvim: nvim prompt timed out")
        return
    except FileNotFoundError:
        respond("deny", "claude.nvim: nvim binary not on PATH")
        return

    out = (result.stdout or "").strip()
    if out == "allow":
        respond("allow", "claude.nvim: user approved")
    elif out == "deny":
        respond("deny", "claude.nvim: user denied")
    else:
        respond("deny", f"claude.nvim: unexpected nvim response: {out!r}")


if __name__ == "__main__":
    main()
