#!/usr/bin/env python3
"""
PreToolUse hook for claude.nvim.

Reads the hook payload from stdin, forwards the tool name + input to the
running nvim instance via --remote-expr, and prints the decision on stdout
in the format Claude Code expects.

Environment:
  CLAUDE_NVIM_SOCKET   Path to v:servername of the caller nvim (required).
  CLAUDE_NVIM_TIMEOUT  Optional override for the remote-expr timeout (seconds).

Exit code is always 0; decisions travel via the JSON on stdout.
"""

from __future__ import annotations
import json
import os
import shlex
import subprocess
import sys
import tempfile
import time


def respond(decision: str, reason: str) -> None:
    sys.stdout.write(json.dumps({
        "continue": True,
        "suppressOutput": True,
        "hookSpecificOutput": {
            "hookEventName": "PreToolUse",
            "permissionDecision": decision,
            "permissionDecisionReason": reason,
        },
    }))
    sys.stdout.write("\n")
    sys.exit(0)


def main() -> None:
    try:
        payload = json.load(sys.stdin)
    except Exception as e:
        respond("deny", f"hook payload parse error: {e}")

    tool_name = payload.get("tool_name", "?")
    tool_input = payload.get("tool_input", {})

    sock = os.environ.get("CLAUDE_NVIM_SOCKET", "").strip()
    if not sock:
        respond("deny", "claude.nvim: no CLAUDE_NVIM_SOCKET set")

    timeout_s = int(os.environ.get("CLAUDE_NVIM_TIMEOUT", "3600"))

    tool_input_lit = json.dumps(json.dumps(tool_input))

    # AskUserQuestion is the CLI's ask-the-user-a-question tool. In -p mode
    # the CLI short-circuits it with an error; we intercept at PreToolUse,
    # render a telescope picker in the user's nvim, and surface the answer
    # back to the model as the tool_result (via deny+reason — the CLI marks
    # it is_error:true, but the reason text IS the answer).
    #
    # The picker CANNOT run inside a --remote-expr evaluation (keyboard
    # input isn't pumped into telescope during synchronous expr eval), so
    # we use a tempfile: remote-expr kicks off an async picker chain that
    # writes the final answer to the file, and this process polls it.
    if tool_name == "AskUserQuestion":
        fd, answer_path = tempfile.mkstemp(prefix="claude-nvim-ask-", suffix=".txt")
        os.close(fd)
        # Sentinel so we don't confuse "file exists but empty" with "done".
        with open(answer_path, "w") as f:
            f.write("<IN-FLIGHT>\n")
        path_lit = json.dumps(answer_path)
        expr = (
            f'v:lua.require("claude.questions").start('
            f'{path_lit}, {tool_input_lit})'
        )
        try:
            subprocess.run(
                ["nvim", "--server", sock, "--remote-expr", expr],
                capture_output=True,
                text=True,
                timeout=10,
            )
        except subprocess.TimeoutExpired:
            respond("deny", "claude.nvim: nvim unreachable")
            return
        except FileNotFoundError:
            respond("deny", "claude.nvim: nvim binary not on PATH")
            return
        deadline = time.monotonic() + timeout_s
        while time.monotonic() < deadline:
            try:
                with open(answer_path) as f:
                    content = f.read()
            except OSError:
                content = ""
            if content and content != "<IN-FLIGHT>\n":
                try:
                    os.unlink(answer_path)
                except OSError:
                    pass
                respond("deny", content.rstrip("\n") or "(no answer)")
                return
            time.sleep(0.2)
        try:
            os.unlink(answer_path)
        except OSError:
            pass
        respond("deny", "claude.nvim: picker timed out")
        return

    tool_name_lit = json.dumps(tool_name)
    expr = (
        f'v:lua.require("claude.permissions").prompt('
        f'{tool_name_lit}, {tool_input_lit})'
    )
    try:
        result = subprocess.run(
            ["nvim", "--server", sock, "--remote-expr", expr],
            capture_output=True,
            text=True,
            timeout=timeout_s,
        )
    except subprocess.TimeoutExpired:
        respond("deny", "claude.nvim: nvim prompt timed out")
        return
    except FileNotFoundError:
        respond("deny", "claude.nvim: nvim binary not on PATH")
        return

    out = (result.stdout or "").strip()
    if out == "allow":
        respond("allow", "claude.nvim: user approved")
    elif out == "deny":
        respond("deny", "claude.nvim: user denied")
    else:
        respond("deny", f"claude.nvim: unexpected nvim response: {out!r}")


if __name__ == "__main__":
    main()
